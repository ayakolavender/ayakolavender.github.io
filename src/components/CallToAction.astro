---
import { site, contact, home } from '../lib/content';
import Icon from './Icon.astro';

const cta = home.cta;
const show = cta?.show !== false;
const email = cta?.email || contact.email || site.profile.email;
const title = cta?.title || 'Want to work together?';
const text =
  cta?.text ||
  "I'm always open to collaborating on research projects, papers, and new ideas. Get in touch.";
const label = cta?.buttonLabel || 'Send an Email';
---
{show && email && (
  <section class="py-9 md:py-11">
    <div class="relative overflow-hidden rounded-3xl bg-accent px-6 py-12 text-center md:px-12 md:py-16">
      <div class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full bg-white/10 blur-2xl" aria-hidden="true"></div>
      <div class="pointer-events-none absolute -bottom-20 -left-12 h-56 w-56 rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
      <div class="relative">
        <h2 class="text-3xl font-extrabold tracking-tight text-accent-text md:text-4xl">{title}</h2>
        <p class="mx-auto mt-3 max-w-xl text-accent-text/85">{text}</p>
        <a
          href={`mailto:${email}`}
          class="mt-7 inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3 font-semibold text-accent shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
        >
          <Icon name="mail" size={18} /> {label}
        </a>
      </div>
    </div>
  </section>
)}
