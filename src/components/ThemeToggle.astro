---
import Icon from './Icon.astro';
---
<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle dark mode"
  class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border text-muted transition hover:text-accent hover:border-accent"
>
  <Icon name="moon" class="block dark:hidden" size={18} />
  <Icon name="sun" class="hidden dark:block" size={18} />
</button>
<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var isDark = document.documentElement.classList.toggle('dark');
      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      } catch (e) {}
    });
  })();
</script>
