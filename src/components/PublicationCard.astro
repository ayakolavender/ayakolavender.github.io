---
import { site } from '../lib/content';
import { authorList } from '../lib/format';
import LinkBadges from './LinkBadges.astro';
import Icon from './Icon.astro';
import type { Publication } from '../lib/schemas';

interface Props {
  pub: Publication;
}
const { pub } = Astro.props;
const authors = authorList(pub.authors);
const me = site.profile.name;
---
<article class="card p-5 transition hover:-translate-y-0.5 hover:shadow-sm">
  {pub.award && (
    <div class="mb-2 inline-flex items-center gap-1.5 text-xs font-medium text-accent">
      <Icon name="award" size={14} /> {pub.award}
    </div>
  )}
  <h3 class="font-serif text-lg font-semibold leading-snug">{pub.title}</h3>
  {authors.length > 0 && (
    <p class="mt-1.5 text-sm text-muted">
      {authors.map((a, i) => (
        <>
          {a === me ? <span class="font-semibold text-text">{a}</span> : a}
          {i < authors.length - 1 ? ', ' : ''}
        </>
      ))}
    </p>
  )}
  <div class="mt-2.5 flex flex-wrap items-center gap-2">
    {pub.venue && <span class="tag">{pub.venue}</span>}
    {pub.year && <span class="tag">{pub.year}</span>}
    {pub.type && <span class="tag">{pub.type}</span>}
  </div>
  {pub.abstract && <p class="mt-3 text-sm leading-relaxed text-muted">{pub.abstract}</p>}
  <LinkBadges links={pub.links} />
</article>
