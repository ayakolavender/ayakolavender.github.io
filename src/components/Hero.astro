---
import { site, home, interests } from '../lib/content';
import { assetUrl } from '../lib/url';
import { pathFor } from '../lib/sections';
import Icon from './Icon.astro';
import SocialLinks from './SocialLinks.astro';
import ImageWithFallback from './ImageWithFallback.astro';

interface Props {
  showPublications?: boolean;
}
const { showPublications = true } = Astro.props;

const p = site.profile;
const photo = home.showPhoto ? p.photo : undefined;
const cv = site.cv ? assetUrl(site.cv) : undefined;
---
<section class="relative overflow-hidden pt-12 pb-8 md:pt-16">
  <div class="absolute inset-0 pointer-events-none">
    <div class="hero-decorations" aria-hidden="true">
      <span class="pulse-node pulse-node-1"></span>
      <span class="pulse-node pulse-node-2"></span>
      <span class="pulse-node pulse-node-3"></span>
      <span class="pulse-node pulse-node-4"></span>
      <span class="circuit-line circuit-line-1"></span>
      <span class="circuit-line circuit-line-2"></span>
      <span class="circuit-line circuit-line-3"></span>
    </div>
  </div>
  <div class="grid items-center gap-10 md:grid-cols-[1.5fr_1fr]">
    <div>
      {home.greeting && <p class="eyebrow rise mb-3">{home.greeting}</p>}
      <h1 class="rise rise-2 text-5xl font-extrabold leading-[1.04] tracking-tight md:text-6xl">
        <span class="gradient-text">{p.name}</span>
      </h1>
      {(p.role || p.affiliation) && (
        <p class="rise rise-2 mt-4 text-lg font-medium text-muted md:text-xl">
          {p.role}{p.role && p.affiliation ? ' · ' : ''}{p.affiliation}
        </p>
      )}
      {site.tagline && <p class="rise rise-3 mt-5 max-w-xl text-lg leading-relaxed">{site.tagline}</p>}
      {interests.length > 0 && (
        <div class="rise rise-3 mt-6 flex flex-wrap gap-2">
          {interests.map((t) => <span class="chip">{t}</span>)}
        </div>
      )}
      <div class="rise rise-4 mt-7 flex flex-wrap items-center gap-3">
        {showPublications && (
          <a class="btn btn-primary hover-glow" href={pathFor('publications')}>
            <Icon name="book-open" size={18} /> Publications
          </a>
        )}
        {cv && (
          <a class="btn btn-ghost hover-glow" href={cv} target="_blank" rel="noopener noreferrer">
            <Icon name="download" size={18} /> Download CV
          </a>
        )}
      </div>
      <div class="rise rise-5 mt-6">
        <SocialLinks />
      </div>
    </div>

    {photo && (
      <div class="rise rise-3 order-first md:order-last">
        <div class="relative mx-auto w-fit md:ml-auto md:mr-0">
          <div class="absolute -inset-4 rounded-[2.25rem] bg-accent-soft blur-2xl" aria-hidden="true"></div>
          <ImageWithFallback
            src={photo}
            alt={p.name}
            class="relative h-48 w-48 rounded-[1.9rem] border border-border object-cover shadow-sm md:h-64 md:w-64"
          />
        </div>
      </div>
    )}
  </div>
</section>
