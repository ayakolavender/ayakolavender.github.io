---
import { render, type CollectionEntry } from 'astro:content';
import Icon from './Icon.astro';
import { withBase } from '../lib/url';
import { formatDate, estimateReadingTime } from '../lib/format';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { Content } = await render(post);
const tags = post.data.tags ?? [];
---
<article class="mx-auto max-w-2xl px-5 py-12 md:py-16">
  <a
    href={withBase('/blog')}
    class="mb-7 inline-flex items-center gap-1 text-sm text-muted transition hover:text-accent"
  >
    <Icon name="arrow-left" size={15} /> Back to blog
  </a>

  {tags.length > 0 && (
    <div class="mb-3 flex flex-wrap gap-1.5">
      {tags.map((t) => <span class="tag">{t}</span>)}
    </div>
  )}

  <h1 class="text-3xl font-bold leading-tight md:text-4xl">{post.data.title}</h1>

  <div class="mt-3 flex flex-wrap items-center gap-4 text-sm text-muted">
    <span class="inline-flex items-center gap-1">
      <Icon name="calendar" size={14} /> {formatDate(post.data.date)}
    </span>
    <span class="inline-flex items-center gap-1">
      <Icon name="clock" size={14} /> {estimateReadingTime(post.body, post.data.readingTime)} min read
    </span>
  </div>

  <div class="prose mt-8">
    <Content />
  </div>

  <a
    href={withBase('/blog')}
    class="mt-12 inline-flex items-center gap-1 text-sm text-accent link-underline"
  >
    <Icon name="arrow-left" size={15} /> Back to blog
  </a>
</article>
