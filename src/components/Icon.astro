// Brand (fill) icons take priority over same-named stroke icons (e.g. "x").
const isFill = fill[name] !== undefined;
const body = (isFill ? fill[name] : stroke[name]) ?? stroke.globe;
---
{isFill ? (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24"
    fill="currentColor" class={className} aria-hidden="true" set:html={body} />
) : (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24"
    fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
    stroke-linejoin="round" class={className} aria-hidden="true" set:html={body} />
)}
