---
import type { CollectionEntry } from 'astro:content';
import PageHeader from './PageHeader.astro';
import Icon from './Icon.astro';
import { withBase } from '../lib/url';
import { formatDate, estimateReadingTime } from '../lib/format';

interface Props {
  posts: CollectionEntry<'blog'>[];
}
const { posts } = Astro.props;
const allTags = Array.from(new Set(posts.flatMap((p) => p.data.tags ?? [])));
---
<section class="mx-auto max-w-3xl px-5 py-12 md:py-16">
  <PageHeader title="Blog" subtitle="Notes, tutorials, and thoughts on my research." />

  {allTags.length > 0 && (
    <div class="mb-7 flex flex-wrap gap-2">
      <button class="tag-btn" data-tag="all" aria-pressed="true">All</button>
      {allTags.map((t) => (
        <button class="tag-btn" data-tag={t} aria-pressed="false">{t}</button>
      ))}
    </div>
  )}

  <div class="space-y-4">
    {posts.map((post) => (
      <a
        href={withBase(`/blog/${post.id}`)}
        data-post
        data-tags={(post.data.tags ?? []).join('|')}
        class="card block p-5 transition hover:-translate-y-0.5 hover:shadow-sm"
      >
        {(post.data.tags ?? []).length > 0 && (
          <div class="mb-2 flex flex-wrap gap-1.5">
            {(post.data.tags ?? []).map((t) => <span class="tag">{t}</span>)}
          </div>
        )}
        <h2 class="font-serif text-xl font-semibold">{post.data.title}</h2>
        {post.data.excerpt && <p class="mt-1.5 text-sm text-muted">{post.data.excerpt}</p>}
        <div class="mt-2.5 flex items-center gap-4 text-xs text-muted">
          <span class="inline-flex items-center gap-1">
            <Icon name="calendar" size={13} />
            {formatDate(post.data.date, { year: 'numeric', month: 'short', day: 'numeric' })}
          </span>
          <span class="inline-flex items-center gap-1">
            <Icon name="clock" size={13} />
            {estimateReadingTime(post.body, post.data.readingTime)} min read
          </span>
        </div>
      </a>
    ))}
  </div>

  <p id="blog-empty" class="card hidden p-6 text-center text-muted">No posts with this tag.</p>
</section>
<script is:inline>
  (function () {
    var btns = Array.prototype.slice.call(document.querySelectorAll('.tag-btn'));
    var posts = Array.prototype.slice.call(document.querySelectorAll('[data-post]'));
    var empty = document.getElementById('blog-empty');
    function apply(tag) {
      var shown = 0;
      posts.forEach(function (el) {
        var tags = (el.getAttribute('data-tags') || '').split('|');
        var ok = tag === 'all' || tags.indexOf(tag) > -1;
        el.classList.toggle('hidden', !ok);
        if (ok) shown++;
      });
      if (empty) empty.classList.toggle('hidden', shown > 0);
      btns.forEach(function (b) {
        b.setAttribute('aria-pressed', String(b.getAttribute('data-tag') === tag));
      });
    }
    btns.forEach(function (b) {
      b.addEventListener('click', function () {
        apply(b.getAttribute('data-tag'));
      });
    });
  })();
</script>
