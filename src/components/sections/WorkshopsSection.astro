---
import { workshops } from '../../lib/content';
import { formatDate } from '../../lib/format';
import Container from '../Container.astro';
import PageHeader from '../PageHeader.astro';
import Icon from '../Icon.astro';
---
<Container class="py-12 md:py-16">
  <PageHeader
    title="Workshops & Conferences"
    eyebrow="Events"
    subtitle="Workshops and conferences I've attended, presented at, or helped organize."
  />
  <ul class="space-y-4">
    {workshops.map((w) => (
      <li class="card p-5">
        <div class="flex items-start justify-between gap-3">
          <h3 class="font-serif text-lg font-bold leading-snug">{w.name}</h3>
          {w.role && <span class="tag shrink-0">{w.role}</span>}
        </div>
        {w.host && <p class="mt-1 text-sm font-medium">{w.host}</p>}
        <div class="mt-1.5 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-muted">
          {w.date && (
            <span class="inline-flex items-center gap-1">
              <Icon name="calendar" size={13} /> {formatDate(w.date, { year: 'numeric', month: 'short' })}
            </span>
          )}
          {w.location && (
            <span class="inline-flex items-center gap-1">
              <Icon name="map-pin" size={13} /> {w.location}
            </span>
          )}
        </div>
        {w.description && <p class="mt-2 text-sm text-muted">{w.description}</p>}
        {w.link && (
          <a
            href={w.link}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 inline-flex items-center gap-1 text-sm text-accent link-underline"
          >
            Details <Icon name="arrow-right" size={14} />
          </a>
        )}
      </li>
    ))}
  </ul>
</Container>
