---
import { talks } from '../../lib/content';
import { formatDate } from '../../lib/format';
import Container from '../Container.astro';
import PageHeader from '../PageHeader.astro';
import LinkBadges from '../LinkBadges.astro';
import Icon from '../Icon.astro';
---
<Container class="py-12 md:py-16">
  <PageHeader title="Talks & Presentations" eyebrow="Speaking" subtitle="Invited talks, conference presentations, and posters." />
  <ul class="space-y-4">
    {talks.map((t) => (
      <li class="card p-5">
        <div class="flex items-start justify-between gap-3">
          <h3 class="font-serif text-lg font-semibold leading-snug">{t.title}</h3>
          {t.type && <span class="tag shrink-0">{t.type}</span>}
        </div>
        {t.event && <p class="mt-1 text-sm font-medium">{t.event}</p>}
        <div class="mt-1.5 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-muted">
          {t.date && (
            <span class="inline-flex items-center gap-1">
              <Icon name="calendar" size={13} /> {formatDate(t.date, { year: 'numeric', month: 'short' })}
            </span>
          )}
          {t.location && (
            <span class="inline-flex items-center gap-1">
              <Icon name="map-pin" size={13} /> {t.location}
            </span>
          )}
        </div>
        {t.description && <p class="mt-2 text-sm text-muted">{t.description}</p>}
        <LinkBadges links={t.links} />
      </li>
    ))}
  </ul>
</Container>
